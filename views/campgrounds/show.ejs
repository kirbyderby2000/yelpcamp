<%- layout('layouts/boilerplate.ejs') %>
<% title= `${campground.title} - YelpCamp` %>
    <!-- Starability (Star CSS Template) -->
    <link rel="stylesheet" href="/starability/starability-basic.min.css">
    <!-- Mapbox GL CSS -->
    <link rel="stylesheet" href="/mapbox-gl/mapbox-gl.css">
    <!-- Showpage CSS -->
    <link rel="stylesheet" href="/css/showPage.css">

    <div class="row justify-content-center my-2">
        <div class="col-12 col-md-6">
            <div class="card w-100">
                <% if(campground.images.length> 1){ %>

                    <div id="carouselExample" class="carousel slide">
                        <div class="carousel-inner">
                            <% for (let index=0; index < campground.images.length; index++) { const
                                img=campground.images[index]; const activeText=index===0 ? "active" : "" ; %>

                                <div class="carousel-item <%= activeText %>">
                                    <img src="<%=img.url %>" class="d-block w-100 object-fit-cover carousel-img" alt="">
                                </div>

                                <% } %>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample"
                            data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselExample"
                            data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>

                    <% } else { %>

                        <img src="<%= campground.firstImage %>" class="card-img-top"
                            alt="Image for <%= campground.title%>">
                        <% } %>
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= campground.title %>
                                </h5>
                                <p class="card-text text-secondary-emphasis">
                                    <%= campground.description %>
                                </p>
                            </div>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">
                                    <%= campground.location %>
                                </li>
                                <li class="list-group-item">Price: <%= campground.priceUSD %>
                                </li>
                            </ul>
                            <div class="card-body">
                                <% if(displayEdit){ %>
                                    <a href="/campgrounds/<%= campground._id %>/edit" class="btn btn-info">Edit
                                        Campground</a>
                                    <% } %>

                                        <a href="/campgrounds/" class="btn btn-primary">All Campgrounds</a>
                            </div>
                            <div class="card-footer text-secondary">
                                Submitted By: <%= campground.author ? campground.author.displayName : 'User Not Found'
                                    %>
                            </div>
            </div>

        </div>
        <div class="col-12 col-md-6">
            <!-- Mapbox Element -->
            <div id="map" class="mb-3" data-geometry="<%=JSON.stringify(campground.geometry)%>"
                data-mapbox="<%= process.env.MAPBOX_TOKEN_PUBLIC_CLIENT %>" data-location="<%= campground.location%>"></div>
            <% if(currentUser){ %>
                <h2>Leave a Review</h2>
                <form action="/reviews/<%= campground._id %>" method="post" class="mb-3 validated-form" novalidate>
                    <div class="">
                        <fieldset class="starability-basic" style="min-height: auto; margin-bottom: 0.5em;">
                            <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked
                                aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="rating" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="rating" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="rating" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="rating" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="rating" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <div class="mb-3">

                        <label for="comment" class="form-label">Review:</label>
                        <textarea name="comment" id="comment" cols="30" rows="3" placeholder="Review Comments..."
                            class="form-control" required></textarea>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Review comment cannot be empty.
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success">Submit Review</button>

                </form>



                <% } %>
                    <div id="reviews-container">
                    </div>
                    <%- partial('../partials/pagination.ejs') %>


        </div>

        <template id="review-template" data-campId="<%= campground._id%>">
            <div class="mb-3 review-card">
                <div class="card">
                    <div class="card-body">
                        <div clss="card-title">
                            <p class="starability-result review-stars" data-rating="x">
                                Rated: X stars
                            </p>
                        </div>
                        <h6 class="card-subtitle mb-2 text-body-secondary review-author">Submitted By: {displayName}
                        </h6>
                        <p class="card-text review-comment"> Review: {review.comment}
                        </p>
                        <form action="/reviews/reviewID?_method=DELETE" method="post" class="review-delete-btn">
                            <button type="submit" class="btn btn-danger">Delete Review</button>
                        </form>

                    </div>
                </div>
            </div>
        </template>


    </div>




    <script src="/mapbox-gl/mapbox-gl.js"></script>
    <script src="/js/displayMap.js"></script>
    <script type="module" src="/js/showCampground.js"></script>